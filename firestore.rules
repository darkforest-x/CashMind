rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation for Transaction
    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'userId', 'amount', 'type', 'category', 'date'])
        && data.id is string && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.amount is number
        && data.type in ['expense', 'income']
        && data.category is string && data.category.size() <= 64
        && data.date is string && data.date.size() == 10
        && (!('currency' in data) || data.currency in ['CNY', 'USD', 'EUR', 'JPY'])
        && (!('note' in data) || (data.note is string && data.note.size() <= 500))
        && (!('source' in data) || data.source in ['manual', 'shortcut']);
    }

    // Validation for Budget
    function isValidBudget(data) {
      return data.keys().hasAll(['id', 'userId', 'month', 'amount'])
        && data.id is string && data.id.size() <= 128
        && data.userId == request.auth.uid
        && data.month is string && data.month.size() == 7
        && data.amount is number;
    }

    match /transactions/{txId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) 
                    && isValidTransaction(request.resource.data)
                    && isValidId(txId);
      allow update: if isOwner(resource.data.userId) 
                    && isOwner(request.resource.data.userId)
                    && isValidTransaction(request.resource.data)
                    && request.resource.data.id == resource.data.id;
    }

    match /budgets/{budgetId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if isOwner(request.resource.data.userId) 
                   && isValidBudget(request.resource.data)
                   && isValidId(budgetId);
    }
  }
}
