HOST=0.0.0.0
PORT=3000
GEMINI_API_KEY=your_gemini_api_key

# Optional. If omitted, the server generates and appends these secrets to .env on first boot.
APP_ACCESS_TOKEN=
SHORTCUT_TOKEN=
SETUP_TOKEN=

# Optional for iOS app base URL (front-end env variable)
VITE_API_BASE_URL=https://your-domain.com
